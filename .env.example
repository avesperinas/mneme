# Copy this file to .env and fill in real values.
# .env is gitignored -- never commit the populated file.

# ---------------------------------------------------------------------------
# Serving profile: gpu | cpu | (empty = auto-detect by scripts/detect.sh)
# ---------------------------------------------------------------------------
SERVING_PROFILE=

# ---------------------------------------------------------------------------
# LLM endpoint -- leave empty to let detect.sh resolve per profile from
# config.yaml. Set them only to override the profile defaults.
#   GPU default: http://vllm:8000/v1   /  Qwen/Qwen2.5-7B-Instruct-AWQ
#   CPU default: http://ollama:11434/v1 /  qwen2.5:3b
# ---------------------------------------------------------------------------
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=not-needed

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=mneme

# ---------------------------------------------------------------------------
# API -- server bind (API_HOST/API_PORT) and client target (API_BASE_URL).
# They differ on purpose: the server binds 0.0.0.0, clients hit a real host.
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
API_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# Embeddings (BGE-M3)
# ---------------------------------------------------------------------------
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=auto

# ---------------------------------------------------------------------------
# Reranker (BGE-reranker-v2-m3)
# ---------------------------------------------------------------------------
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=auto

# ---------------------------------------------------------------------------
# Vault -- absolute path on the host, bind-mounted into the ingestion container
# ---------------------------------------------------------------------------
VAULT_PATH=/path/to/your/obsidian/vault

# ---------------------------------------------------------------------------
# Langfuse observability (phase 8)
# ---------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ---------------------------------------------------------------------------
# Auth gateway (phase 8) -- required before any public exposure
# ---------------------------------------------------------------------------
AUTH_TOKEN=
